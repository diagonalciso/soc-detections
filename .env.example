# soc-detections — Sigma detection-as-code
DET_HOST=0.0.0.0
DET_PORT=8103
# Sigma rule tree (bundled SigmaHQ submodule).
SIGMA_DIR=./sigma/rules
# Where "Mark deployed" writes generated Wazuh rule XML (copy to manager's /var/ossec/etc/rules/).
WAZUH_OUT_DIR=./out
# Base numeric id for generated Wazuh rules (local rules use 100000+).
WAZUH_BASE_ID=100000
